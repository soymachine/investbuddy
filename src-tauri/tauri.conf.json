{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InvestBuddy",
  "version": "0.1.0",
  "identifier": "com.soymachine.investbuddy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "InvestBuddy",
        "width": 1180,
        "height": 860,
        "minWidth": 960,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png"]
  }
}
